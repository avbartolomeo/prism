{
  "name": "prism",
  "version": "0.1.0",
  "private": true,
  "description": "MCP Context Router + Agent Observability",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/types",
    "packages/proxy",
    "packages/cli",
    "packages/dashboard"
  ],
  "scripts": {
    "build": "turbo run build",
